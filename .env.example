# CreatorFlow 환경 변수
# 이 파일을 .env로 복사하고 실제 값을 입력하세요.
# cp .env.example .env

# ── Supabase ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Gemini API ──
VITE_GEMINI_API_KEY=your-gemini-api-key

# ── 앱 설정 ──
VITE_APP_NAME=CreatorFlow
VITE_DEV_MODE=true
